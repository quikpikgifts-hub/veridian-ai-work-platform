{
  "buildCommand":    "npm run build",
  "outputDirectory": ".next",
  "framework":       "nextjs",
  "regions":         ["iad1"],

  "functions": {
    "app/api/ai-agent/route.ts":        { "maxDuration": 55 },
    "app/api/generate-report/route.ts": { "maxDuration": 55 },
    "app/api/create-incident/route.ts": { "maxDuration": 55 },
    "app/api/consultation/route.ts":    { "maxDuration": 30 },
    "app/api/audit/route.ts":           { "maxDuration": 15 },
    "app/api/health/route.ts":          { "maxDuration": 10 }
  },

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff"  },
        { "key": "X-Frame-Options",        "value": "DENY"     },
        { "key": "Cache-Control",          "value": "no-store, must-revalidate" },
        { "key": "X-Robots-Tag",           "value": "noindex"  }
      ]
    },
    {
      "source": "/(dashboard|incidents|risk-assessments|threat-intel|ai-operations|workflows|fleet|reports|analytics|clients|activity|notifications|users|settings|admin)(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" }
      ]
    }
  ]
}
