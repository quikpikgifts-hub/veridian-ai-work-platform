# ═══════════════════════════════════════════════════════════════
# VERIDIAN RISK PLATFORM — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED: OpenAI ────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Optional: Override the default OpenAI model ─────────────────
# Default: gpt-4o — override if you want gpt-4-turbo, gpt-4.1, etc.
# OPENAI_MODEL=gpt-4o

# ── REQUIRED FOR AUTH: Supabase ─────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project → Settings → API
# NEXT_PUBLIC_ prefix means these are exposed to the browser (safe — anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Optional: Supabase Service Role (admin ops) ─────────────────
# WARNING: NEVER expose this to the browser. Server-side only.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Optional: App configuration ─────────────────────────────────
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# VERCEL DEPLOYMENT
# Set all variables in: Vercel → Project → Settings → Environment Variables
# Apply to: Production, Preview, Development
#
# Minimum required for production:
#   OPENAI_API_KEY
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
# ═══════════════════════════════════════════════════════════════
